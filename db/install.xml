<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/msteams/db" VERSION="2026051000" COMMENT="XMLDB file for local_msteams"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_msteams_slot" COMMENT="Primary slot records for MS Teams appointments">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="eventid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" DEFAULT="open"/>
        <FIELD NAME="hostid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="basedescription" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="msteams_join_url" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="graph_event_id" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="graph_organizer" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="eventiduniq" TYPE="unique" FIELDS="eventid"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="status_ix" UNIQUE="false" FIELDS="status"/>
        <INDEX NAME="hostid_ix" UNIQUE="false" FIELDS="hostid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_msteams_attendee" COMMENT="Attendee user mappings for slot records">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="slotid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="slotid_userid_uix" UNIQUE="true" FIELDS="slotid, userid"/>
        <INDEX NAME="slotid_ix" UNIQUE="false" FIELDS="slotid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_msteams_reminder" COMMENT="Reminder send history for slot records">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="slotid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="reminderkey" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="recipientuserid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="timesent" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="slotid_reminderkey_userid_uix" UNIQUE="true" FIELDS="slotid, reminderkey, recipientuserid"/>
        <INDEX NAME="slotid_ix" UNIQUE="false" FIELDS="slotid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
